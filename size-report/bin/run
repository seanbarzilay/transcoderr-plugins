#!/bin/sh
# size-report -- record before/after file size and compression ratio so
# notify templates can reference {{ steps.size_report.before_bytes }},
# {{ steps.size_report.after_bytes }}, {{ steps.size_report.ratio_pct }},
# {{ steps.size_report.saved_bytes }}. (The `steps.` prefix is required --
# CEL templates only see the top-level Context fields: file, probe,
# steps, failed.)
#
# Provides two step names from this one entrypoint:
#   - size.report.before  runs before plan.execute, captures original size
#   - size.report.after   runs after output, captures final size + diff
#
# Pure POSIX shell + coreutils + awk -- no python, jq, or anything else
# the runtime images don't already ship. The full README.md walks through
# how to wire it into a flow.
#
# Protocol: reads two JSON-RPC lines on stdin (init, execute), emits JSON
# event lines on stdout (log, context_set, result). See
# crates/transcoderr/src/plugins/subprocess.rs for the host side.
set -eu

# JSON output helpers. Messages we emit are static strings we author here,
# so no escaping is required. We never echo untrusted strings (file paths,
# user input) into stdout JSON.

emit_log() {
    printf '{"event":"log","msg":"%s"}\n' "$1"
}

emit_result_ok() {
    printf '{"event":"result","status":"ok","outputs":{}}\n'
    exit 0
}

emit_result_err() {
    # Static reason strings keep us out of escaping trouble. Any place we'd
    # want to interpolate (e.g. a path) is left out of the message itself
    # and surfaced via emit_log earlier.
    printf '{"event":"result","status":"error","error":{"msg":"%s"}}\n' "$1"
    exit 0
}

# Surgical JSON extraction. The protocol is host-controlled and the shapes
# are stable, so awk regex against the known field positions is reliable
# enough -- much more than parsing arbitrary JSON would be. Pathnames with
# embedded double-quotes would break this (and a lot of other shell
# plumbing); everything else is fine.

extract_step_id() {
    awk '
        match($0, /"step_id"[[:space:]]*:[[:space:]]*"[^"]*"/) {
            v = substr($0, RSTART, RLENGTH)
            sub(/.*"step_id"[[:space:]]*:[[:space:]]*"/, "", v)
            sub(/"$/, "", v)
            print v
        }
    ' <<EOF
$1
EOF
}

# Extracts ctx.file.path. Anchors the match to "file":{"path":"..."} so we
# don't pick up some other field named "path" elsewhere in the context.
extract_file_path() {
    awk '
        match($0, /"file"[[:space:]]*:[[:space:]]*\{[^}]*"path"[[:space:]]*:[[:space:]]*"[^"]*"/) {
            v = substr($0, RSTART, RLENGTH)
            sub(/.*"path"[[:space:]]*:[[:space:]]*"/, "", v)
            sub(/"$/, "", v)
            print v
        }
    ' <<EOF
$1
EOF
}

# Reads ctx.steps.size_report.before_bytes if the prior `before` step
# wrote it. Empty output if the key is absent.
extract_before_bytes() {
    awk '
        match($0, /"size_report"[[:space:]]*:[[:space:]]*\{[^}]*"before_bytes"[[:space:]]*:[[:space:]]*[0-9]+/) {
            v = substr($0, RSTART, RLENGTH)
            sub(/.*"before_bytes"[[:space:]]*:[[:space:]]*/, "", v)
            print v
        }
    ' <<EOF
$1
EOF
}

file_size() {
    # `wc -c < "$path"` is portable across Linux + macOS. stat(1)'s flags
    # differ between platforms (-c on GNU, -f on BSD) so we avoid it.
    wc -c < "$1" | tr -d ' \n'
}

# --- main -----------------------------------------------------------------

# init line (ignored)
read -r _ || emit_result_err "no init message on stdin"
# execute line
read -r EXEC || emit_result_err "no execute message on stdin"

STEP_ID=$(extract_step_id "$EXEC")
FILE_PATH=$(extract_file_path "$EXEC")

if [ -z "$STEP_ID" ]; then
    emit_result_err "could not parse step_id from execute message"
fi
if [ -z "$FILE_PATH" ]; then
    emit_result_err "could not parse ctx.file.path from execute message"
fi
if [ ! -f "$FILE_PATH" ]; then
    emit_log "size-report: file does not exist on disk"
    emit_result_err "file does not exist"
fi

case "$STEP_ID" in
"size.report.before")
    BEFORE=$(file_size "$FILE_PATH")
    emit_log "size.report.before: ${BEFORE} bytes"
    printf '{"event":"context_set","key":"size_report","value":{"before_bytes":%s}}\n' "$BEFORE"
    emit_result_ok
    ;;

"size.report.after")
    BEFORE=$(extract_before_bytes "$EXEC")
    if [ -z "$BEFORE" ]; then
        emit_result_err "no before_bytes in ctx -- run size.report.before earlier in the flow"
    fi
    AFTER=$(file_size "$FILE_PATH")
    SAVED=$((BEFORE - AFTER))
    # POSIX shell has no float math; awk does the percentage with one
    # decimal place. Emits 0.0 when before is zero so we never divide by
    # zero, and never clamps -- a negative ratio (file got bigger) is a
    # real signal the operator probably wants in their notify message.
    RATIO=$(awk -v b="$BEFORE" -v a="$AFTER" 'BEGIN { if (b+0 > 0) printf "%.1f", (b-a)/b*100; else printf "0.0" }')
    emit_log "size.report.after: ${BEFORE} -> ${AFTER} bytes (${RATIO}% saved)"
    printf '{"event":"context_set","key":"size_report","value":{"before_bytes":%s,"after_bytes":%s,"saved_bytes":%s,"ratio_pct":%s}}\n' \
        "$BEFORE" "$AFTER" "$SAVED" "$RATIO"
    emit_result_ok
    ;;

*)
    emit_result_err "unknown step_id"
    ;;
esac
