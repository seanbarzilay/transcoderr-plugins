      "homepage": "https://github.com/seanbarzilay/transcoderr-plugins/tree/main/whisper",
      "min_transcoderr_version": "0.27.0",
      "kind": "subprocess",
      "provides_steps": [
        "whisper.transcribe"
      ],
      "runtimes": [
        "python3",
        "ffprobe"
      ],
      "deps": "python3 -m venv ./venv && ./venv/bin/pip install faster-whisper nvidia-cublas-cu12 'nvidia-cudnn-cu12==9.*'"
    },
    {
      "name": "whisperx",
      "version": "0.1.2",
      "summary": "Forced phoneme alignment for whisper output via WhisperX (wav2vec2-based).",
      "tarball_url": "https://raw.githubusercontent.com/seanbarzilay/transcoderr-plugins/main/tarballs/whisperx-0.1.2.tar.gz",
      "tarball_sha256": "8376dde666f9a8c584d7a9cc11811ca0b4e80cf9f4997c8fc2461a60c7a6502a",
      "homepage": "https://github.com/seanbarzilay/transcoderr-plugins/tree/main/whisperx",
      "min_transcoderr_version": "0.27.0",
      "kind": "subprocess",
      "provides_steps": [
        "whisperx.align",
        "whisperx.transcribe_aligned"
      ],
      "runtimes": [
        "python3",
        "ffmpeg"
      ],
      "deps": "python3 -m venv ./venv && ./venv/bin/pip install 'torch==2.3.1' 'torchaudio==2.3.1' && ./venv/bin/pip install 'pyannote.audio==3.3.2' 'faster-whisper==1.0.0' 'ctranslate2==4.4.0' transformers pandas nltk nvidia-cublas-cu12 'nvidia-cudnn-cu12==9.*' && ./venv/bin/pip install --no-deps 'whisperx==3.1.6'"
    }
  ]
