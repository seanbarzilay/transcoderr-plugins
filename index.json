{
  "schema_version": 1,
  "catalog_name": "transcoderr official",
  "catalog_url": "https://github.com/seanbarzilay/transcoderr-plugins",
  "plugins": [
    {
      "name": "size-report",
      "version": "0.1.2",
      "summary": "Records before/after byte counts and the compression ratio so notify templates can render saved-percentage stats.",
      "tarball_url": "https://raw.githubusercontent.com/seanbarzilay/transcoderr-plugins/main/tarballs/size-report-0.1.2.tar.gz",
      "tarball_sha256": "502332deef5ac8ac4a9a83a0197a2f6570a2f10d5c9f3dca8b2c7e4e5894fbc2",
      "homepage": "https://github.com/seanbarzilay/transcoderr-plugins/tree/main/size-report",
      "min_transcoderr_version": "0.19.0",
      "kind": "subprocess",
      "provides_steps": [
        "size.report.before",
        "size.report.after"
      ],
      "runtimes": []
    },
    {
      "name": "subsync",
      "version": "0.1.2",
      "summary": "Aligns an out-of-sync .srt to the audio of a video file using ffsubsync (VAD-based).",
      "tarball_url": "https://raw.githubusercontent.com/seanbarzilay/transcoderr-plugins/main/tarballs/subsync-0.1.2.tar.gz",
      "tarball_sha256": "eb4a94373370574525aac1d7a173e786a1025f12ef3e82fbb8b8a0794502313a",
      "homepage": "https://github.com/seanbarzilay/transcoderr-plugins/tree/main/subsync",
      "min_transcoderr_version": "0.27.0",
      "kind": "subprocess",
      "provides_steps": [
        "subsync.align"
      ],
      "runtimes": [
        "python3",
        "ffmpeg"
      ],
      "deps": "python3 -m venv ./venv && ./venv/bin/pip install webrtcvad-wheels && ./venv/bin/pip install 'auditok==0.1.5' chardet charset_normalizer 'faust-cchardet;python_version<\"3.13\"' ffmpeg-python 'numpy>=1.12.0' 'pysubs2>=1.2.0' rich setuptools 'srt>=3.0.0' tqdm typing_extensions && ./venv/bin/pip install --no-deps ffsubsync"
    },
    {
      "name": "upscale",
      "version": "0.1.0",
      "summary": "Upscales the video stream with Real-ESRGAN (ncnn-vulkan). Designed for SD-source upgrades.",
      "tarball_url": "https://raw.githubusercontent.com/seanbarzilay/transcoderr-plugins/main/tarballs/upscale-0.1.0.tar.gz",
      "tarball_sha256": "41faee31cd9bf914325293b1b29bebaaaadb646468c512d695d4bd302e975154",
      "homepage": "https://github.com/seanbarzilay/transcoderr-plugins/tree/main/upscale",
      "min_transcoderr_version": "0.27.0",
      "kind": "subprocess",
      "provides_steps": [
        "upscale.video"
      ],
      "runtimes": [
        "python3",
        "ffmpeg",
        "ffprobe",
        "realesrgan-ncnn-vulkan"
      ],
      "deps": null
    },
    {
      "name": "whisper",
      "version": "0.1.6",
      "summary": "Generates a sidecar .srt for the output file using faster-whisper. GPU auto-detected.",
      "tarball_url": "https://raw.githubusercontent.com/seanbarzilay/transcoderr-plugins/main/tarballs/whisper-0.1.6.tar.gz",
      "tarball_sha256": "46c718477744c0a4669926b0e6f20d44fe30fa12e9715da8aaf86a7bc70903dd",
      "homepage": "https://github.com/seanbarzilay/transcoderr-plugins/tree/main/whisper",
      "min_transcoderr_version": "0.27.0",
      "kind": "subprocess",
      "provides_steps": [
        "whisper.transcribe"
      ],
      "runtimes": [
        "python3",
        "ffprobe"
      ],
      "deps": "python3 -m venv ./venv && ./venv/bin/pip install faster-whisper nvidia-cublas-cu12 'nvidia-cudnn-cu12==9.*'"
    },
    {
      "name": "whisperx",
      "version": "0.1.5",
      "summary": "Forced phoneme alignment for whisper output via WhisperX (wav2vec2-based).",
      "tarball_url": "https://raw.githubusercontent.com/seanbarzilay/transcoderr-plugins/main/tarballs/whisperx-0.1.5.tar.gz",
      "tarball_sha256": "9b34a0bb38891d81cbf5520e4360cf28d730eb27597097f51226d03ec87b4b09",
      "homepage": "https://github.com/seanbarzilay/transcoderr-plugins/tree/main/whisperx",
      "min_transcoderr_version": "0.27.0",
      "kind": "subprocess",
      "provides_steps": [
        "whisperx.align",
        "whisperx.transcribe_aligned"
      ],
      "runtimes": [
        "python3",
        "ffmpeg"
      ],
      "deps": "python3 -m venv ./venv && ./venv/bin/pip install whisperx nvidia-cublas-cu12 'nvidia-cudnn-cu12==9.*'"
    }
  ]
}
