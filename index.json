      "kind": "subprocess",
      "provides_steps": [
        "size.report.before",
        "size.report.after"
      ],
      "runtimes": []
    },
    {
      "name": "subsync",
      "version": "0.1.0",
      "summary": "Aligns an out-of-sync .srt to the audio of a video file using ffsubsync (VAD-based).",
      "tarball_url": "https://raw.githubusercontent.com/seanbarzilay/transcoderr-plugins/main/tarballs/subsync-0.1.0.tar.gz",
